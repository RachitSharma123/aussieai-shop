---
const links = [['Services','#services'],['Industries','#industries'],['Process','#process'],['FAQ','#faq'],['Contact','#contact'],['Privacy Policy','#contact'],['Terms','#contact']];
---
<footer class="footer">
  <div class="container footer-inner">
    <div>
      <a href="#top" class="footer-brand">Aussie <span>AI</span></a>
      <p>AI agents and automation systems for Australian businesses.</p>
      <p>Melbourne, Victoria, Australia</p>
    </div>
    <div class="footer-links">{links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    <p class="footer-copy">© {new Date().getFullYear()} Aussie AI</p>
  </div>
</footer>
