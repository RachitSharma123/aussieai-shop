---
const links = [['Home','/'],['Services','/services'],['Industries','/industries'],['Process','/process'],['Results','/results'],['FAQ','/faq'],['Contact','/contact'],['Privacy Policy','/privacy'],['Terms','/terms']];
---
<footer class="footer">
  <div class="container footer-inner">
    <div>
      <a href="/" class="footer-brand">Aussie <span>AI</span></a>
      <p>AI agents and automation systems for Australian businesses.</p>
      <p>Melbourne, Victoria, Australia</p>
    </div>
    <div class="footer-links">{links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    <p class="footer-copy">© {new Date().getFullYear()} Aussie AI</p>
  </div>
</footer>
