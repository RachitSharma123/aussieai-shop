<!-- ========== AURORA SHADER BACKGROUND ========== -->
<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.js';

const canvas = document.getElementById('hero-bg');
if (!canvas) return;

const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
renderer.setPixelRatio(1); // keep cheap

const scene  = new THREE.Scene();
const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

const vert = `
  varying vec2 vUv;
  void main() { vUv = uv; gl_Position = vec4(position, 1.0); }
`;

const frag = `
  precision mediump float;
  uniform float uTime;
  uniform vec2  uMouse;
  varying vec2  vUv;

  // 2D simplex noise — by Ian McEwan / ashima
  vec3 mod289v(vec3 x){return x-floor(x*(1./289.))*289.;}
  vec2 mod289v(vec2 x){return x-floor(x*(1./289.))*289.;}
  vec3 permute(vec3 x){return mod289v(((x*34.)+1.)*x);}
  float snoise(vec2 v){
    const vec4 C=vec4(.211324865405187,.366025403784439,-.577350269189626,.024390243902439);
    vec2 i=floor(v+dot(v,C.yy));
    vec2 x0=v-i+dot(i,C.xx);
    vec2 i1=(x0.x>x0.y)?vec2(1.,0.):vec2(0.,1.);
    vec4 x12=x0.xyxy+C.xxzz; x12.xy-=i1;
    i=mod289v(i);
    vec3 p=permute(permute(i.y+vec3(0.,i1.y,1.))+i.x+vec3(0.,i1.x,1.));
    vec3 m=max(.5-vec3(dot(x0,x0),dot(x12.xy,x12.xy),dot(x12.zw,x12.zw)),0.);
    m=m*m; m=m*m;
    vec3 x=2.*fract(p*C.www)-1.;
    vec3 h=abs(x)-.5;
    vec3 ox=floor(x+.5);
    vec3 a0=x-ox;
    m*=1.79284291400159-.85373472095314*(a0*a0+h*h);
    vec3 g;
    g.x=a0.x*x0.x+h.x*x0.y;
    g.yz=a0.yz*x12.xz+h.yz*x12.yw;
    return 130.*dot(m,g);
  }

  void main(){
    vec2 uv = vUv;
    vec2 m  = uMouse * .18;
    float t = uTime  * .10;

    float n1 = snoise(uv * 1.6 + vec2(t,       t*.65)  + m);
    float n2 = snoise(uv * 3.0 - vec2(t*.55,   0.)     + m*.5);
    float n3 = snoise(uv * 5.5 + vec2(t*.25,  -t*.4));
    float n  = n1*.55 + n2*.30 + n3*.15;

    // Light pastel aurora color stops
    vec3 cBase  = vec3(.960, .978, .992);  // near-white
    vec3 cMint  = vec3(.810, .960, .900);  // soft mint
    vec3 cSky   = vec3(.800, .935, .975);  // soft sky blue
    vec3 cVivid = vec3(.760, .965, .870);  // bright mint-green

    vec3 col = mix(cBase, cMint,  smoothstep(-.5, .1, n));
    col      = mix(col,   cSky,   smoothstep(-.1, .4, n)*.50);
    col      = mix(col,   cVivid, smoothstep( .4, .9, n)*.35);

    // Very subtle vignette for depth
    float vig = 1. - length((uv-.5)*1.3);
    vig = smoothstep(.0, .9, vig);
    col = mix(vec3(.955,.975,.992), col, .35 + vig*.65);

    gl_FragColor = vec4(col, 1.0);
  }
`;

const uniforms = {
  uTime:  { value: 0.0 },
  uMouse: { value: new THREE.Vector2(0, 0) },
};
scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), new THREE.ShaderMaterial({ vertexShader: vert, fragmentShader: frag, uniforms })));

let targetMouse = new THREE.Vector2();
document.addEventListener('mousemove', e => {
  targetMouse.set((e.clientX/innerWidth)*2-1, -(e.clientY/innerHeight)*2+1);
});

const resize = () => {
  const h = document.getElementById('hero-section')?.offsetHeight || innerHeight;
  renderer.setSize(innerWidth, h);
};
resize();
window.addEventListener('resize', resize);

const clock = new THREE.Clock();
(function tick() {
  requestAnimationFrame(tick);
  uniforms.uTime.value  = clock.getElapsedTime();
  uniforms.uMouse.value.lerp(targetMouse, .04);
  renderer.render(scene, camera);
})();
</script>

<!-- ========== WIREFRAME SPHERE ========== -->
<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.js';

const canvas = document.getElementById('hero-3d');
if (!canvas) return;

const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.setSize(340, 340);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
camera.position.z = 4.5;

// Torus knot wireframe
const geo  = new THREE.TorusKnotGeometry(1.2, 0.38, 128, 16);
const mat  = new THREE.MeshBasicMaterial({ color: 0x00d46a, wireframe: true });
const mesh = new THREE.Mesh(geo, mat);
scene.add(mesh);

let mx = 0, my = 0;
document.addEventListener('mousemove', e => {
  mx = (e.clientX / innerWidth - .5) * 2;
  my = -(e.clientY / innerHeight - .5) * 2;
});

const clock = new THREE.Clock();
(function tick() {
  requestAnimationFrame(tick);
  const t = clock.getElapsedTime();
  mesh.rotation.x = t * .25 + my * .3;
  mesh.rotation.y = t * .35 + mx * .3;
  renderer.render(scene, camera);
})();
</script>

<!-- ========== GSAP + TILT + CHAT ========== -->
<script is:inline>
(function () {
  function init() {
    if (typeof gsap === 'undefined') { setTimeout(init, 80); return; }

    // Reveal content
    gsap.from('.hero-badge, .hero-title, .hero-desc, .hero-actions, .hero-proof', {
      opacity: 0, y: 32, duration: 0.9, stagger: 0.13, ease: 'power3.out', delay: 0.3,
    });

    // Float cards
    gsap.to('.float-card', {
      y: -16, duration: 3.5, yoyo: true, repeat: -1,
      ease: 'sine.inOut', stagger: 1.0,
    });
  }
  document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();

  // 3D tilt on chat mockup
  const visual = document.getElementById('heroVisual');
  const mockup = document.getElementById('chatMockup');
  if (visual && mockup) {
    visual.addEventListener('mousemove', e => {
      const r = mockup.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width  - .5) * 2;
      const y = ((e.clientY - r.top)  / r.height - .5) * 2;
      mockup.style.transform = `perspective(900px) rotateY(${x*14}deg) rotateX(${-y*10}deg) translateZ(14px)`;
    });
    visual.addEventListener('mouseleave', () => { mockup.style.transform = ''; });
  }

  // Bot reply
  setTimeout(() => {
    const t = document.getElementById('typingMsg');
    if (t) t.innerHTML = '<div class="bubble">Done! Booked for 2:30 PM tomorrow. I\'ll send a reminder 1 hour before. Anything else? 😊</div><div class="msg-time mono">9:03 AM</div>';
  }, 3000);
})();
</script>
