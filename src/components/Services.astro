---
const services = [
  ['AI Chat Agents', 'Answer website and message enquiries, qualify leads, collect details and book appointments.'],
  ['AI Voice Agents', 'Answer calls, handle missed call follow up, capture caller details and route urgent requests to humans.'],
  ['Inbox Agents', 'Sort emails, summarise threads, draft replies, flag urgent messages and keep communication moving.'],
  ['Workflow Automation', 'Connect leads, bookings, forms, emails, spreadsheets, CRMs and alerts so updates happen automatically.'],
  ['AI Strategy and Automation Audit', 'Map your workflow, find bottlenecks and identify the highest impact automation opportunities.'],
  ['Custom AI Operations Systems', 'Build multiple AI agents working together across sales, support, admin, reporting and operations.'],
];
---
<section class="section" id="services">
  <div class="container section-head">
    <p class="eyebrow">What Aussie AI does</p>
    <h2>AI agents that work inside your business.</h2>
    <p class="section-copy">Aussie AI designs practical AI systems around the tools your business already uses.</p>
  </div>
  <div class="container bento services-grid">
    {services.map(([title, copy]) => <article class="card"><h3>{title}</h3><p>{copy}</p><a href="#contact">Book an audit</a></article>)}
  </div>
</section>
