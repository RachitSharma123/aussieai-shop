---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { services, industries, processSteps, dashboard } from '../data/site';
const topServices = services.slice(0, 4);
const topIndustries = industries.slice(0, 6);
const schema = { '@context': 'https://schema.org', '@type': 'LocalBusiness', name: 'Aussie AI', url: 'https://aussieai.shop', description: 'Custom AI agents and automation systems for Australian businesses.', address: { '@type': 'PostalAddress', addressLocality: 'Melbourne', addressRegion: 'VIC', addressCountry: 'AU' }, areaServed: 'Australia' };
---
<Base>
  <Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(schema)} /></Fragment>
  <Nav />
  <main id="top">
    <section class="hero section ambient-section">
      <div class="ambient-orb orb-one"></div><div class="ambient-orb orb-two"></div><div class="ambient-grid"></div>
      <div class="container narrow reveal">
        <p class="eyebrow">· Melbourne based · Built for Australian businesses ·</p>
        <h1>Scale Your Operations<br><span class="h1-accent">Without Scaling Your Team</span></h1>
        <p class="lead">Custom AI agents that handle enquiries, missed calls, bookings and admin, built around the tools you already use.</p>
        <div class="actions hero-actions"><a class="btn primary" href="/contact">Book Free AI Audit</a><a class="btn secondary" href="/services">See What We Build</a></div>
        <div class="trust hero-trust" aria-label="Trust points">{['Melbourne based', 'Built for Australian businesses', 'Works with existing tools', 'No technical knowledge required', 'Start small, scale later', 'Human handoff included'].map((t) => <span>{t}</span>)}</div>
      </div>
    </section>

    <section class="section" id="services">
      <div class="container section-head reveal"><p class="eyebrow">What Aussie AI does</p><h2>Practical AI agents for everyday operations.</h2><p class="section-copy">Start with one useful automation, then expand when the workflow proves value.</p></div>
      <div class="container bento four">{topServices.map((item) => <article class="card reveal"><h3>{item.title}</h3><p>{item.does}</p><a href="/services">View services</a></article>)}</div>
    </section>

    <section class="section">
      <div class="container section-head reveal"><p class="eyebrow">Industries</p><h2>Built for the businesses Australia actually runs on.</h2></div>
      <div class="container bento three">{topIndustries.map((item) => <article class="card reveal"><h3>{item.title}</h3><p>{item.problem}</p><a href="/industries">Explore industries</a></article>)}</div>
    </section>

    <section class="section">
      <div class="container section-head reveal"><p class="eyebrow">Process</p><h2>Simple process. No tech overwhelm.</h2></div>
      <div class="container steps preview-steps">{processSteps.slice(0, 3).map((step, i) => <article class="card step reveal"><span>Step {i + 1}</span><h3>{step.title}</h3><p>{step.happens}</p></article>)}</div>
      <div class="container centre-actions"><a class="btn secondary" href="/process">See the full process</a></div>
    </section>

    <section class="section audit"><div class="container narrow reveal"><p class="eyebrow">Free audit first</p><h2>Every workflow is different.</h2><p>Some businesses need one simple automation. Others need a complete AI operations system across calls, inboxes, CRM, bookings and reporting. Aussie AI starts with a free audit so we can recommend the simplest solution that actually makes sense.</p><a class="btn primary" href="/contact">Book Free AI Audit</a></div></section>

    <section class="section final-cta"><div class="container narrow reveal"><h2>Ready to see what AI can automate in your business?</h2><p>Book a free AI audit and we will show you where Aussie AI can help you respond faster, capture more leads and reduce manual work.</p><a class="btn primary" href="/contact">Book Free AI Audit</a></div></section>
  </main>
  <Footer />
  <script is:inline>
    const dashboard = document.querySelector('[data-parallax]');
    window.addEventListener('scroll', () => { if (!dashboard || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return; dashboard.style.setProperty('--lift', `${Math.min(window.scrollY * 0.018, 16)}px`); }, { passive: true });
    const insight = document.getElementById('dashboardInsight');
    document.querySelectorAll('[data-dashboard-row]').forEach((row) => row.addEventListener('click', () => { document.querySelectorAll('[data-dashboard-row]').forEach((item) => item.classList.remove('active')); row.classList.add('active'); if (insight) insight.textContent = row.dataset.detail || ''; }));
  </script>
</Base>
