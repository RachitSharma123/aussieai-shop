---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  ['AI Chat Agents','Answer website and message enquiries, qualify leads, collect details, and book appointments.'],
  ['AI Voice Agents','Answer calls, handle missed-call follow-ups, capture caller details, and route urgent requests to humans.'],
  ['Inbox Agents','Sort emails, summarise threads, draft replies, flag urgent messages, and keep communication moving.'],
  ['Workflow Automation','Connect your tools so leads, bookings, forms, emails, spreadsheets, CRMs, and alerts update automatically.'],
  ['AI Strategy & Automation Audit','Map your workflow, find bottlenecks, and identify the highest-impact automation opportunities.'],
  ['Custom AI Operations Systems','Build multiple AI agents working together across sales, support, admin, reporting, and operations.'],
];
const without = ['Leads wait too long for replies','Calls get missed during busy hours','After-hours enquiries go cold','Staff answer the same questions daily','CRM updates are forgotten','Emails pile up','Admin slows down growth'];
const withAi = ['Leads get fast responses','Missed calls trigger automatic follow-up','Common questions are answered 24/7','Customer details are captured cleanly','CRMs and spreadsheets update automatically','Staff receive clear summaries','More work gets handled without more hiring'];
const solutions = [
 ['Lead Response Automation','Instantly respond to website forms, missed calls, social DMs, and customer enquiries.'],['AI Receptionist','A 24/7 front desk that answers questions, captures details, books appointments, and routes important conversations.'],['Missed-Call Text-Back','Automatically text missed callers, collect job details, and help recover leads before they contact a competitor.'],['Google Review Booster','Request reviews, monitor new feedback, and draft professional replies for Google Business reviews.'],['Cafe Booking & DM Bot','Handle Instagram, Facebook, WhatsApp, menu questions, opening hours, and booking enquiries.'],['NDIS Progress Note Assistant','Turn rough support notes into cleaner draft notes that are easier to review and organise.'],['CRM & Workflow Automation','Connect forms, emails, calendars, CRMs, spreadsheets, invoices, alerts, and internal systems.'],['Custom Website + AI Automation','Build modern websites with AI chat, smart forms, booking flows, lead capture, and automation built in.'],
];
const industries = [
 ['Tradies','Recover missed calls, qualify job requests, send follow-ups, and keep bookings moving while the team is on site.'],['Cafes & Restaurants','Answer menu, opening hours, table booking, event, and social DM enquiries without leaving customers waiting.'],['NDIS Providers','Organise enquiries, intake details, progress note drafts, reminders, and handovers with safer human review points.'],['Clinics & Allied Health','Handle appointment enquiries, reminders, intake forms, FAQs, and reception admin around your existing calendar.'],['Retail & Local Shops','Reply to product, stock, hours, returns, and delivery questions across web, email, and messages.'],['Real Estate','Capture buyer, renter, and vendor enquiries, qualify leads, draft replies, and keep inspections organised.'],['Consultants','Triage enquiries, book calls, collect briefs, prepare summaries, and keep follow-up consistent.'],['Agencies','Automate lead intake, reporting reminders, client updates, ticket triage, and internal admin.'],['Service Businesses','Respond faster, qualify requests, update systems, and give staff cleaner daily handovers.'],
];
const outcomes = ['Faster lead response','Fewer missed enquiries','Less repetitive admin','More after-hours opportunities captured','Cleaner staff handover','Better follow-up','Smoother customer experience'];
const steps = [['Audit','We review your current workflow, tools, repetitive tasks, and missed opportunities.'],['Automation Map','We show what should be automated, what should stay human, and where the biggest value is.'],['Build','We design, build, test, and connect the AI agent or workflow into your existing systems.'],['Launch','We launch the system and make sure your team knows how to use it.'],['Improve','We monitor, refine, and improve the automation as your business grows.']];
const faqs = [
 ['What does Aussie AI actually build?','Custom AI agents and automations for enquiries, calls, inboxes, bookings, CRM updates, reporting, reviews, and admin workflows.'],['Is this just a chatbot?','No. Chat can be one part of the system, but the work is usually connecting conversations to your tools and processes.'],['What is an AI agent?','An AI agent is a practical assistant that can understand a request, follow rules, collect details, trigger workflows, and hand over when needed.'],['Can it answer calls?','Yes. Voice agents can answer calls, collect details, book appointments, and escalate urgent matters to your team.'],['Can it work with my current website?','Usually, yes. We can add agents, smart forms, booking flows, and tracking to most modern websites.'],['Can it connect with my CRM or calendar?','Yes. We commonly connect calendars, CRMs, forms, spreadsheets, inboxes, SMS, and workflow tools.'],['Do I need technical knowledge?','No. We handle the strategy, build, testing, launch, and support in plain language.'],['Will this replace my staff?','The goal is to reduce repetitive admin and missed enquiries, not remove human judgement or customer care.'],['What happens if the AI gets something wrong?','We design guardrails, approval steps, escalation paths, and monitoring so humans stay in control of important decisions.'],['Can we start with one small automation?','Yes. Many businesses start with one high-impact workflow, then expand once it proves useful.'],['Do you maintain the system after launch?','Yes. Support, monitoring, refinements, and improvements can be included after launch.'],['How do we get started?','Book a free AI audit. We will review your workflow and show the simplest path forward.'],
];
const dashboard = ['New lead captured','Missed call followed up','Website enquiry qualified','Inbox reply drafted','CRM updated','Booking added to calendar','Google review reply drafted','Workflow completed'];
const schema = { '@context':'https://schema.org', '@type':'LocalBusiness', name:'Aussie AI', url:'https://aussieai.shop', description:'Custom AI agents and automation systems for Australian businesses.', address:{'@type':'PostalAddress', addressLocality:'Melbourne', addressRegion:'VIC', addressCountry:'AU'}, areaServed:'Australia' };
---
<Base>
  <Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(schema)} /></Fragment>
  <Nav />
  <main id="top">
    <section class="hero section">
      <div class="container hero-grid">
        <div class="hero-copy reveal"><p class="eyebrow">Melbourne based · Built for Australian businesses</p><h1>Scale Your Operations Without Scaling Your Team</h1><p class="lead">Aussie AI builds custom AI agents and automation systems that handle enquiries, missed calls, bookings, inboxes, follow-ups, CRM updates, reviews, and repetitive admin — so your team can focus on real work.</p><div class="actions"><a class="btn primary" href="#contact">Book Free AI Audit</a><a class="btn secondary" href="#services">See What We Build</a></div><div class="trust">{['Melbourne based','Built for Australian businesses','Works with your existing tools','No technical knowledge required','Strategy, build, and support included'].map(t => <span>{t}</span>)}</div></div>
        <div class="dashboard reveal"> <div class="dash-top"><span></span><b>AI operations dashboard</b><em>Live workflow</em></div>{dashboard.map((d,i)=><div class="dash-row" style={`--i:${i}`}><span class="pulse"></span><strong>{d}</strong><small>{i % 2 ? 'Reviewed' : 'Automated'}</small></div>)}</div>
      </div>
    </section>
    <section class="section" id="services"><div class="container"><p class="eyebrow">What Aussie AI does</p><h2>AI agents that work inside your business.</h2><p class="section-copy">Aussie AI designs and builds practical AI systems that connect to your website, inbox, phone, CRM, calendar, forms, spreadsheets, and daily workflows.</p><div class="bento">{services.map(([t,d])=><article class="card"><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
    <section class="section split-section"><div class="container"><h2>Manual work is costing more than you think.</h2><div class="compare"><article class="card danger"><h3>Without Aussie AI</h3>{without.map(x=><p>✕ {x}</p>)}</article><article class="card success"><h3>With Aussie AI</h3>{withAi.map(x=><p>✓ {x}</p>)}</article></div></div></section>
    <section class="section" id="solutions"><div class="container"><p class="eyebrow">Solutions</p><h2>Start with one automation or build a complete AI operations system.</h2><div class="bento four">{solutions.map(([t,d])=><article class="card"><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
    <section class="section" id="industries"><div class="container"><p class="eyebrow">Industries</p><h2>Built for the businesses Australia actually runs on.</h2><div class="bento three">{industries.map(([t,d])=><article class="card"><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
    <section class="section" id="results"><div class="container"><p class="eyebrow">Results</p><h2>Designed around real business outcomes.</h2><div class="outcomes">{outcomes.map(o=><span>{o}</span>)}</div><p class="note">Results depend on business type, enquiry volume, tools, and workflow complexity.</p></div></section>
    <section class="section" id="process"><div class="container"><p class="eyebrow">Process</p><h2>Simple process. No tech overwhelm.</h2><div class="steps">{steps.map(([t,d],i)=><article class="card step"><span>Step {i+1}</span><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
    <section class="section tools"><div class="container"><p class="eyebrow">Integrations</p><h2>Works with the tools you already use.</h2><p>Websites, forms, Google Sheets, Airtable, Google Calendar, Gmail, Outlook, WhatsApp, SMS, Instagram, Facebook, HubSpot, GoHighLevel, Zapier, Make, n8n, Stripe, Xero, QuickBooks, databases, dashboards, and custom APIs.</p></div></section>
    <section class="section audit"><div class="container narrow"><h2>Every business workflow is different.</h2><p>Some businesses need one simple automation. Others need a complete AI operations system across calls, inboxes, CRM, bookings, and reporting. That’s why Aussie AI starts with a free audit before recommending a solution.</p><a class="btn primary" href="#contact">Book Free AI Audit</a><p class="note">We’ll review your workflow, show what can be automated, and recommend the simplest path forward.</p></div></section>
    <section class="section" id="faq"><div class="container"><p class="eyebrow">FAQ</p><h2>Common questions.</h2><div class="faq-list">{faqs.map(([q,a])=><details class="faq-item"><summary>{q}</summary><p>{a}</p></details>)}</div></div></section>
    <section class="section final-cta"><div class="container narrow"><h2>Ready to see what AI can automate in your business?</h2><p>Book a free AI audit and we’ll show you where Aussie AI can help you save time, respond faster, capture more leads, and reduce manual work.</p><a class="btn primary" href="#contact">Book Free AI Audit</a><p class="note">No pressure. No technical jargon. Just a clear automation roadmap for your business.</p></div></section>
    <section class="section contact" id="contact"><div class="container contact-grid"><div><p class="eyebrow">Contact</p><h2>Book your free AI audit.</h2><p>Tell us what is slowing your team down. We will come back with practical automation opportunities for your business.</p></div><form class="card form" action="https://formspree.io/f/mpqopryb" method="POST"><input name="name" placeholder="Name" required /><input name="business" placeholder="Business name" required /><input name="email" type="email" placeholder="Email" required /><input name="phone" placeholder="Phone" /><input name="website" placeholder="Website" /><input name="business_type" placeholder="Type of business" /><textarea name="automate" placeholder="What do you want to automate?" rows="3"></textarea><textarea name="tools" placeholder="Current tools used" rows="3"></textarea><select name="preferred_contact"><option>Preferred contact method</option><option>Email</option><option>Phone</option><option>SMS</option></select><textarea name="message" placeholder="Message" rows="4"></textarea><button class="btn primary" type="submit">Book Free AI Audit</button></form></div></section>
  </main>
  <Footer />
</Base>
