---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Pricing from '../components/Pricing.astro';
import HowFaqContact from '../components/HowFaqContact.astro';
import Footer from '../components/Footer.astro';

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "AussieAI",
  "description": "AI chatbots, workflow automation, missed-call text-back, Google review boosting, and AI receptionists for Melbourne small businesses including tradies, cafes, clinics, and NDIS providers.",
  "url": "https://aussieai.shop",
  "email": "hello@aussieai.shop",
  "areaServed": {
    "@type": "City",
    "name": "Melbourne",
    "sameAs": "https://www.wikidata.org/wiki/Q3141"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Melbourne",
    "addressRegion": "VIC",
    "addressCountry": "AU"
  },
  "openingHours": "Mo-Su 00:00-24:00",
  "priceRange": "$$",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AI Automation Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Tradie AI Pack",
          "description": "AI phone answering, missed-call text-back, WhatsApp agents and quote automation for Melbourne tradies."
        },
        "price": "40",
        "priceCurrency": "AUD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "40",
          "priceCurrency": "AUD",
          "unitText": "month"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "NDIS Provider AI Pack",
          "description": "AI enquiry agent, participant intake automation, and NDIS progress note generator for disability providers in Victoria."
        },
        "price": "150",
        "priceCurrency": "AUD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "150",
          "priceCurrency": "AUD",
          "unitText": "month"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cafe Booking & DM Bot",
          "description": "AI chatbot for Melbourne cafes that handles Instagram DMs, Facebook messages, and WhatsApp — answering questions and capturing table bookings automatically."
        },
        "price": "250",
        "priceCurrency": "AUD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "79",
          "priceCurrency": "AUD",
          "unitText": "month"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Google Review Booster",
          "description": "Automated SMS review requests after every job or visit, plus AI-drafted replies to all Google reviews for Melbourne small businesses."
        },
        "price": "49",
        "priceCurrency": "AUD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "49",
          "priceCurrency": "AUD",
          "unitText": "month"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need to know anything about AI or tech?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not at all. We handle 100% of the setup and management. You just tell us what you need and we build it."
      }
    },
    {
      "@type": "Question",
      "name": "How long does setup take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most setups are live within 48 hours of our first call. Complex builds might take up to a week."
      }
    },
    {
      "@type": "Question",
      "name": "Can I cancel anytime?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. No lock-in contracts. If you want to cancel, just let us know with 30 days notice and that's it."
      }
    },
    {
      "@type": "Question",
      "name": "What if my customers don't like chatting with AI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The AI always has an option to connect to a real person. It handles the simple stuff so you can focus on real conversations."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data safe?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We use Australian-compliant cloud infrastructure and never share your data with third parties."
      }
    },
    {
      "@type": "Question",
      "name": "Can you work with my existing software?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most likely yes. We integrate with booking systems, Google Calendar, Xero, MYOB, and most common tools."
      }
    }
  ]
};
---

<Base>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Nav />
  <main>
    <Hero />
    <Services />
    <Pricing />
    <HowFaqContact />
  </main>
  <Footer />
  <script src="/widget.js" defer></script>
</Base>
