---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Book a Free AI Audit: Aussie AI" description="Book a free Aussie AI audit for custom AI agents and automation systems.">
  <Nav />
  <main id="top">
    <section class="section hero">
      <div class="container narrow">
        <p class="eyebrow">Free AI audit</p>
        <h1>Let us map what AI can automate in your business.</h1>
        <p class="lead">No pressure and no technical jargon. Tell us about your workflow and we will recommend the simplest useful automation path.</p>
        <a class="btn primary" href="/#contact">Book Free AI Audit</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
